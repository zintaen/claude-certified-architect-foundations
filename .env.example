# Copy to .env.local for local npm / Docker Compose.
# Never commit .env.local. Do not invent production Paddle keys.

# --- Site / launch gates (local defaults) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
HOST_CUTOVER_REDIRECT=off
ENTITLEMENTS_ENFORCED=off

# --- Supabase (from `npx supabase status` after `npx supabase start`) ---
# Demo keys below are the well-known local Supabase defaults — OK for local only.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# Docker Compose app → host Supabase (uncomment when using `docker compose up`):
# NEXT_PUBLIC_SUPABASE_URL=http://host.docker.internal:54321

# --- Paddle (sandbox / local) ---
# Honest checkout needs a real Paddle sandbox account (see docs/tasks/task-PAY-002-mor-checkout-ppp/BLOCKER.md).
# Until then, leave client token empty OR enable local mock (never on production):
PADDLE_ENV=sandbox
# NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
# PADDLE_API_KEY=
# PADDLE_WEBHOOK_SECRET=
# PADDLE_PRICE_ID_MAP={"per_exam_pass":{"tier1":{"USD":"pri_…"},"tier2":{"USD":"pri_…"}},…}

# Local-only PAY-002 exercise (signed webhook fixtures + mock checkout UI). Safe placeholders only.
PADDLE_DEV_MOCK=1
NEXT_PUBLIC_PADDLE_DEV_MOCK=1
PADDLE_USE_FIXTURE_IDS=1
PADDLE_WEBHOOK_SECRET=local_dev_paddle_webhook_secret
# Optional: fixed user UUID for mock grants (must exist in public.users)
# PADDLE_DEV_MOCK_USER_ID=11111111-1111-1111-1111-111111111111
