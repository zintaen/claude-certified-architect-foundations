# Copy to .env.local for local npm / Docker Compose.
# Production until LAUNCH: keep NEXT_PUBLIC_SITE_URL on ccaf (or unset).

NEXT_PUBLIC_SITE_URL=http://localhost:3000
HOST_CUTOVER_REDIRECT=off
ENTITLEMENTS_ENFORCED=off

# From `npx supabase status` after `npx supabase start`:
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Do not invent production Paddle keys. Sandbox only when testing checkout:
# NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
# PADDLE_API_KEY=
# PADDLE_WEBHOOK_SECRET=
